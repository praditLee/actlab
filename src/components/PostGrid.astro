---
// src/components/PostGrid.astro
import { Image } from "astro:assets";
import { getCollection } from "astro:content";
import FormattedDate from "./FormattedDate.astro";

interface Props {
  categories?: string[];
  tags?: string[];
  slugs?: string[];
  limit?: number;
  columns?: 2 | 3 | 4;
  collection?: "blog" | "pages" | "all";
}

const {
  categories = [],
  tags = [],
  slugs = [],
  limit,
  columns = 3,
  collection = "all",
} = Astro.props;

// ✨ สร้างตัวจับคู่เลขคอลัมน์ กับคลาสของ Tailwind
const columnClasses = {
  2: "lg:columns-2",
  3: "lg:columns-3",
  4: "lg:columns-4",
};

// ดึงคลาสมาใช้ ถ้าไม่ระบุ หรือใส่เลขแปลกๆ มา ให้โชว์ 3 คอลัมน์เป็นค่ามาตรฐาน
const desktopColumns = columnClasses[columns] || columnClasses[3];

// ✨ 1. กวาดข้อมูลมาจากทั้ง 2 โฟลเดอร์ (Blog และ Pages)
const allBlogs = await getCollection("blog").catch(() => []);
const allPages = await getCollection("pages").catch(() => []);
let allPosts = [];
if (collection === "blog") {
  allPosts = allBlogs; // เอาเฉพาะ blog
} else if (collection === "pages") {
  allPosts = allPages; // เอาเฉพาะ pages
} else {
  allPosts = [...allBlogs, ...allPages]; // เอาทั้งหมดมารวมกัน
}

// ✨ 2. ระบบกรองข้อมูลที่แม่นยำขึ้น
let filteredPosts = allPosts.filter((post) => {
  if (categories.length === 0 && tags.length === 0 && slugs.length === 0) {
    return true;
  }

  const postCategories = post.data.categories || [];
  const postTags = post.data.tags || [];

  // ตัดนามสกุลไฟล์ออกให้เกลี้ยง (ป้องกันบั๊กชื่อไฟล์ตีกัน) เช่น my-post.md -> my-post
  const cleanId = post.id.replace(/\.[^/.]+$/, "");

  const matchCategory = categories.some((c) => postCategories.includes(c));
  const matchTag = tags.some((t) => postTags.includes(t));

  // เช็คทั้งแบบตัดและไม่ตัดนามสกุล เพื่อความชัวร์ 100%
  const matchSlug = slugs.some((s) => s === cleanId || s === post.id);

  return matchCategory || matchTag || matchSlug;
});

// ✨ 3. เรียงตามวันที่ (และป้องกันหน้าเว็บพัง กรณีที่บางหน้าเพจไม่ได้ใส่วันที่ไว้)
filteredPosts.sort((a, b) => {
  const dateA = a.data.date ? new Date(a.data.date).valueOf() : 0;
  const dateB = b.data.date ? new Date(b.data.date).valueOf() : 0;
  return dateB - dateA;
});

if (limit) {
  filteredPosts = filteredPosts.slice(0, limit);
}

const categoryMap: Record<string, string> = {
  knowledge: "ความรู้",
  "network-org": "การจัดตั้งเครือข่าย",
  "group-formation": "การจัดตั้งกลุ่ม",
  "action-design": "ออกแบบปฏิบัติการ",
  "communicate-action": "ปฏิบัติการสื่อสาร",
  security: "ความปลอดภัย",
  heal: "การเยียวยา",
  tiptechnic: "เทคนิคและเคล็ดลับ",
  "direct-action": "ปฏิบัติการท้าทายซึ่งหน้า",
  ทั่วไป: "ทั่วไป",
};

const getThaiCategory = (enCategory: string) => {
  return categoryMap[enCategory] || enCategory;
};
---

<div class={`columns-1 sm:columns-2 ${desktopColumns} gap-6 space-y-6`}>
  {
    filteredPosts.length > 0 ? (
      filteredPosts.map((post) => {
        const postCategories = post.data.categories || ["ทั่วไป"];

        // ✨ 4. สลับลิงก์อัตโนมัติ: ถ้าดึงมาจาก blog ให้ไป /blog/ ถ้าดึงมาจาก pages ให้ไป /
        const postUrl =
          post.collection === "blog" ? `/blog/${post.id}/` : `/${post.id}/`;

        return (
          <article class="post-card break-inside-avoid bg-white rounded-3xl overflow-hidden shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_8px_30px_rgb(0,0,0,0.12)] transition-all duration-500 group border border-gray-100">
            <a href={postUrl} class="block">
              {post.data.coverImage && (
                <div class="relative overflow-hidden">
                  <Image
                    width={720}
                    height={720}
                    src={post.data.coverImage}
                    alt={post.data.title || ""}
                    class="w-full h-auto object-cover transform group-hover:scale-105 transition-transform duration-700 ease-out"
                  />
                  <div class="absolute top-4 left-4 flex flex-wrap gap-2">
                    {postCategories.map((cat) => (
                      <span class="bg-white/90 backdrop-blur-sm px-3 py-1 rounded-full text-xs font-bold text-gray-800 shadow-sm">
                        {getThaiCategory(cat)}
                      </span>
                    ))}
                  </div>
                </div>
              )}

              <div class="p-6">
                {/* ตรวจสอบก่อนว่ามีวันที่ไหม ถึงจะแสดงผล */}
                {post.data.date && (
                  <p class="text-xs font-medium text-gray-400 mb-3 flex items-center gap-1.5">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                      />
                    </svg>
                    <FormattedDate date={post.data.date} />
                  </p>
                )}
                <h4 class="text-xl font-bold text-gray-900 group-hover:text-blue-600 transition-colors leading-snug mb-3">
                  {post.data.title}
                </h4>
                {post.data.description && (
                  <p class="text-gray-600 text-sm line-clamp-3 leading-relaxed">
                    {post.data.description}
                  </p>
                )}
              </div>
            </a>
          </article>
        );
      })
    ) : (
      <div class="col-span-full py-12 text-center text-gray-500 bg-gray-50 rounded-3xl border border-dashed border-gray-200">
        <p>ไม่มีบทความที่ตรงกับเงื่อนไข</p>
      </div>
    )
  }
</div>
