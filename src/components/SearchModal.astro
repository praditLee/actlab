---
// src/components/SearchModal.astro
---

<button
  id="search-trigger"
  class="p-2 text-gray-600 hover:text-gray-900 transition-colors rounded-full hover:bg-gray-100"
  aria-label="ค้นหา"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    class="h-6 w-6"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
  </svg>
</button>

<div
  id="search-modal"
  class="fixed inset-0 z-[100] hidden bg-gray-900/50 backdrop-blur-sm flex items-start justify-center pt-20 px-4"
>
  <div
    class="bg-white w-full max-w-2xl rounded-2xl shadow-2xl overflow-hidden flex flex-col"
    id="search-container"
  >
    <div class="relative flex items-center p-4 border-b border-gray-100">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-6 w-6 text-gray-400 absolute left-6"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
      </svg>
      <input
        type="text"
        id="search-input"
        placeholder="ค้นหาคู่มือ, บทความ..."
        class="w-full pl-12 pr-10 py-3 text-lg bg-transparent border-none focus:ring-0 focus:outline-none placeholder-gray-400 text-gray-800"
        autocomplete="off"
      />
      <button
        id="search-close"
        class="absolute right-4 p-2 text-gray-400 hover:text-gray-600 rounded-md hover:bg-gray-100 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <div class="max-h-[60vh] overflow-y-auto p-2" id="search-results">
      <div class="p-8 text-center text-gray-500">
        พิมพ์คำค้นหาเพื่อเริ่มต้น...
      </div>
    </div>
  </div>
</div>

<script>
  let searchData: any[] = [];
  let isLoaded = false;

  const modal = document.getElementById("search-modal");
  const trigger = document.getElementById("search-trigger");
  const closeBtn = document.getElementById("search-close");
  const input = document.getElementById("search-input") as HTMLInputElement;
  const resultsContainer = document.getElementById("search-results");

  const openModal = async () => {
    modal?.classList.remove("hidden");
    input?.focus();

    if (!isLoaded) {
      resultsContainer!.innerHTML = `<div class="p-8 text-center text-gray-500">กำลังโหลดข้อมูล...</div>`;
      try {
        const res = await fetch("/search.json");
        searchData = await res.json();
        isLoaded = true;
        resultsContainer!.innerHTML = `<div class="p-8 text-center text-gray-500">พิมพ์คำค้นหาเพื่อเริ่มต้น...</div>`;
      } catch (err) {
        resultsContainer!.innerHTML = `<div class="p-8 text-center text-red-500">เกิดข้อผิดพลาดในการโหลดข้อมูล</div>`;
      }
    }
  };

  const closeModal = () => {
    modal?.classList.add("hidden");
    if (input) input.value = "";
    if (isLoaded && resultsContainer) {
      resultsContainer.innerHTML = `<div class="p-8 text-center text-gray-500">พิมพ์คำค้นหาเพื่อเริ่มต้น...</div>`;
    }
  };

  input?.addEventListener("input", (e) => {
    const query = (e.target as HTMLInputElement).value.toLowerCase().trim();

    if (!query) {
      resultsContainer!.innerHTML = `<div class="p-8 text-center text-gray-500">พิมพ์คำค้นหาเพื่อเริ่มต้น...</div>`;
      return;
    }

    // ✨ 1. อัปเกรด: เพิ่มเงื่อนไขให้ค้นหาจาก Tags ด้วย
    const filtered = searchData.filter((item) => {
      const matchTitle = item.title.toLowerCase().includes(query);
      const matchDesc = item.description.toLowerCase().includes(query);
      const matchTags = item.tags
        ? item.tags.some((tag: string) => tag.toLowerCase().includes(query))
        : false;

      return matchTitle || matchDesc || matchTags;
    });

    // ✨ 2. อัปเกรด: สร้าง HTML โชว์ Tags ด้านล่างของผลลัพธ์
    if (filtered.length > 0) {
      resultsContainer!.innerHTML = filtered
        .map((item) => {
          // วนลูปสร้างกล่อง Tag เล็กๆ
          const tagsHtml =
            item.tags && item.tags.length > 0
              ? `<div class="flex flex-wrap gap-1.5 mt-2">
              ${item.tags.map((tag: string) => `<span class="text-[10px] font-semibold text-blue-600 bg-blue-50 border border-blue-100 px-2 py-0.5 rounded-md">#${tag}</span>`).join("")}
             </div>`
              : "";

          return `
          <a href="${item.url}" class="block p-4 hover:bg-gray-50 rounded-xl transition-colors mb-1 group border border-transparent hover:border-gray-100">
            <div class="flex items-center justify-between">
              <h3 class="text-lg font-medium text-gray-900 group-hover:text-blue-600 transition-colors">${item.title}</h3>
              <span class="text-xs font-medium text-gray-400 bg-gray-100 px-2 py-1 rounded-full shrink-0 ml-2">${item.type}</span>
            </div>
            ${item.description ? `<p class="text-sm text-gray-500 mt-1 line-clamp-1">${item.description}</p>` : ""}
            ${tagsHtml}
          </a>
        `;
        })
        .join("");
    } else {
      resultsContainer!.innerHTML = `<div class="p-8 text-center text-gray-500">ไม่พบผลลัพธ์สำหรับ "${query}"</div>`;
    }
  });

  trigger?.addEventListener("click", openModal);
  closeBtn?.addEventListener("click", closeModal);
  modal?.addEventListener("click", (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && !modal?.classList.contains("hidden"))
      closeModal();
  });
</script>
