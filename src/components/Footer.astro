---
const today = new Date();
---

<footer
  class="w-full bg-gradient-to-r from-green-100 via-yellow-100 to-red-200 mt-auto border-t border-white/50"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 md:py-14">
    <div class="flex flex-col items-center justify-center gap-6">
      <p class="text-gray-800 font-medium text-center">
        &copy; {today.getFullYear()} ACTLAB. All rights reserved.
      </p>

      <div class="flex items-center gap-5 text-gray-700">
        <a
          href="https://www.facebook.com/ActLabThailand"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-black hover:scale-110 transition-all duration-300"
        >
          <span class="sr-only">Follow Act Lab Facebook</span>
          <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M23.9981 11.9991C23.9981 5.37216 18.626 0 11.9991 0C5.37216 0 0 5.37216 0 11.9991C0 17.9882 4.38789 22.9522 10.1242 23.8524V15.4676H7.07758V11.9991H10.1242V9.35553C10.1242 6.34826 11.9156 4.68714 14.6564 4.68714C15.9692 4.68714 17.3424 4.92149 17.3424 4.92149V7.87439H15.8294C14.3388 7.87439 13.8739 8.79933 13.8739 9.74824V11.9991H17.2018L16.6698 15.4676H13.8739V23.8524C19.6103 22.9522 23.9981 17.9882 23.9981 11.9991Z"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
