          color: "bg-[#A7C7E7]",
        },
        {
          score: 3,
          text: "เชื่อมเพื่อนเชื่อมเครือข่ายแล้วยกระดับการทำงานสู่ผลลัพธ์ นั่นคือยกระดับจากเคสเรื่องเขื่อนไปสู่ประเด็นการจัดการน้ำหรือกระบวนการมีส่วนร่วมของประชาชนกับโครงการของรัฐ",
          color: "bg-[#8B8BF7]",
        },
      ],
    },
    {
      id: 8,
      title: "8. เชื่อมภาคได้",
      image: "/images/AL_10_09.png",
      options: [
        { score: 0, text: "ยังไม่มีการเชื่อมในระดับภาค", color: "bg-white" },
        {
          score: 1,
          text: "รู้จักกลุ่มอื่นๆ ที่ทำงานคล้ายกันในระดับภาค",
          color: "bg-[#EFE5C2]",
        },
        {
          score: 2,
          text: "มีการพูดคุย ร่วมงานเป็นครั้งคราวกับกลุ่มอื่นๆ ในภาค",
          color: "bg-[#A7C7E7]",
        },
        {
          score: 3,
          text: "มีแผน มีกิจกรรมร่วมกันในฐานะเครือข่ายระดับภาค และมีส่วนร่วมในกลไกประสานงานระดับภาค",
          color: "bg-[#8B8BF7]",
        },
      ],
    },
    {
      id: 9,
      title: "9. เชื่อมขบวนการต่อสู้เพื่อประชาธิปไตยในภาพใหญ่ได้",
      image: "/images/AL_10_10.png",
      options: [
        {
          score: 0,
          text: "ยังไม่มีช่องทางการเชื่อมขบวนอย่างเป็นรูปธรรม",
          color: "bg-white",
        },
        {
          score: 1,
          text: "มีการเชื่อมในระดับกิจกรรมเป็นครั้งคราว",
          color: "bg-[#EFE5C2]",
        },
        {
          score: 2,
          text: "มีการเชื่อมในระดับกิจกรรมอย่างต่อเนื่อง",
          color: "bg-[#A7C7E7]",
        },
        {
          score: 3,
          text: "มีส่วนร่วมในการออกแบบวางแผนงานในขบวน",
          color: "bg-[#8B8BF7]",
        },
      ],
    },
  ];

  // 🔥 1. ตั้งชื่อ Key สำหรับเก็บข้อมูล (เปลี่ยนชื่อโปรเจกต์ได้ตามใจชอบ)
  const STORAGE_KEY = "actlab_assessment_save_v1";

  // State เก็บค่า
  let currentStep = 0;
  let answers = new Array(questions.length).fill(null); // เก็บคำตอบ (0-3)

  // DOM Elements
  const quizView = document.getElementById("quiz-view");
  const resultView = document.getElementById("result-view");
  const qImage = document.getElementById("q-image") as HTMLImageElement;
  const optionsContainer = document.getElementById("options-container");
  const btnPrev = document.getElementById("btn-prev") as HTMLButtonElement;
  const btnNext = document.getElementById("btn-next") as HTMLButtonElement;
  const stepIndicator = document.getElementById("step-indicator");

  // 🔥 2. ฟังก์ชันโหลดข้อมูล (เพิ่มใหม่)
  function loadProgress() {
    const savedData = localStorage.getItem(STORAGE_KEY);
    if (savedData) {
      try {
        const parsed = JSON.parse(savedData);
        // เช็คว่าจำนวนข้อตรงกันไหม (เผื่อเราแก้โจทย์ทีหลัง)
        if (parsed.answers && parsed.answers.length === questions.length) {
          answers = parsed.answers;
          currentStep = parsed.currentStep || 0;
        }
      } catch (e) {
        console.error("Save file corrupted, resetting...");
        localStorage.removeItem(STORAGE_KEY);
      }
    }
  }

  // 🔥 3. ฟังก์ชันบันทึกข้อมูล (เพิ่มใหม่)
  function saveProgress() {
    localStorage.setItem(
      STORAGE_KEY,
      JSON.stringify({
        answers: answers,
        currentStep: currentStep,
      }),
    );
  }

  // 🔥 4. ฟังก์ชันล้างข้อมูลเมื่อกด "ทำใหม่" (เพิ่มใหม่)
  window.restartQuiz = function () {
    // ใช้ window เพื่อให้ปุ่ม onclick ใน HTML เรียกใช้ได้ง่าย
    if (confirm("ต้องการล้างข้อมูลและเริ่มใหม่ทั้งหมดใช่หรือไม่?")) {
      localStorage.removeItem(STORAGE_KEY);
      location.reload();
    }
  };

  // ฟังก์ชันแสดงผล
  function renderUI() {
    const q = questions[currentStep];

    qImage.src = q.image;
    // อัปเดต alt ของรูปภาพตาม Title (ตามที่คุณขอไว้)
    qImage.alt = q.title;

    stepIndicator.innerText = `${currentStep + 1} / ${questions.length}`;

    optionsContainer.innerHTML = "";
    q.options.forEach((opt) => {
      const isSelected = answers[currentStep] === opt.score;

      const btn = document.createElement("div");
      // (Style คงเดิม...)
      btn.className = `relative flex items-stretch rounded-2xl overflow-hidden cursor-pointer shadow-sm border-2 transition-all group ${opt.color} ${isSelected ? "border-black scale-[1.02] shadow-md ring-2 ring-black/20" : "border-transparent hover:scale-[1.01] hover:shadow"}`;

      btn.onclick = () => selectAnswer(opt.score);

      btn.innerHTML = `
        <div class="w-16 flex flex-col justify-center items-center shrink-0 border-r border-black/10">
          <span class="text-lg md:text-3xl font-black text-black leading-none">${opt.score}</span>
          <span class="text-[10px] font-bold text-black/50">คะแนน</span>
        </div>
        <div class="p-2 md:p-6 flex items-center">
          <div class="text-xs md:text-xl text-gray-800 leading-snug text-left">${opt.text}</div>
        </div>
        
        ${isSelected ? '<div class="absolute top-2 right-2 text-green-600 bg-white rounded-full p-1 shadow"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg></div>' : ""}
      `;

      optionsContainer.appendChild(btn);
    });

    // จัดการปุ่ม Nav
    btnPrev.disabled = currentStep === 0;

    if (currentStep === questions.length - 1) {
      btnNext.innerText = "สรุปผลลัพธ์ ⭐";
      btnNext.classList.remove("bg-black");
      btnNext.classList.add("bg-orange-600");
    } else {
      btnNext.innerText = "ถัดไป →";
      btnNext.classList.add("bg-black");
      btnNext.classList.remove("bg-orange-600");
    }
  }

  function selectAnswer(score) {
    answers[currentStep] = score;
    saveProgress(); // 🔥 บันทึกทันทีที่เลือก
    renderUI();
  }

  function handlePrev() {
    if (currentStep > 0) {
      currentStep--;
      saveProgress(); // 🔥 บันทึกหน้าที่อยู่ปัจจุบัน
      renderUI();
    }
  }

  function handleNext() {
    if (answers[currentStep] === null) {
      alert("กรุณาเลือกคำตอบก่อนไปข้อถัดไปครับ");
      return;
    }

    if (currentStep < questions.length - 1) {
      currentStep++;
      saveProgress(); // 🔥 บันทึกหน้าที่อยู่ปัจจุบัน
      renderUI();
    } else {
      calculateResult();
    }
  }

  btnPrev.addEventListener("click", handlePrev);
  btnNext.addEventListener("click", handleNext);

  function calculateResult() {
    // 🔥 บันทึกสถานะว่าทำเสร็จแล้ว (เผื่อ Refresh หน้าผลลัพธ์จะได้ไม่หาย)
    saveProgress();

    quizView.classList.add("hidden");
    resultView.classList.remove("hidden");

    const total = answers.reduce((a, b) => a + b, 0);

    // (ส่วนสร้างกราฟ คงเดิม...)
    // หมายเหตุ: เช็ค id canvas ให้ตรงกับ HTML นะครับ
    const ctx = document.getElementById("radarChart");
    if (ctx) {
      // Destroy old chart if exists (prevent overlap on reload)
      const existingChart = Chart.getChart(ctx);
      if (existingChart) existingChart.destroy();

      new Chart(ctx, {
        type: "radar",
        data: {
          labels: questions.map((q) => q.id.toString()),
          datasets: [
            // 🟡 Layer 1 (ล่างสุด): พื้นที่สีเหลือง (Level 1)
            {
              data: new Array(9).fill(1),
              backgroundColor: "rgba(255, 240, 150, 1)", // ปรับสีเหลืองให้สว่างและทึบขึ้น
              borderColor: "transparent", // ซ่อนขอบสีเหลือง
              pointRadius: 0, // ซ่อนจุด
              fill: true,
              order: 3, // วาดก่อน (อยู่ล่างสุด)
            },

            // 🔵 Layer 2 (กลาง): พื้นที่สีฟ้า (คะแนนของคุณ - เฉพาะสีพื้น)
            {
              data: answers,
              backgroundColor: "rgba(110, 115, 250, 0.5)", // ปรับสีให้เป็น "น้ำเงินม่วง" (Periwinkle) ที่สดกว่าเดิม
              borderColor: "transparent", // ซ่อนขอบ (เราจะไปวาดขอบใน Layer บนสุดแทน)
              pointRadius: 0, // ซ่อนจุด
              fill: true,
              order: 2, // วาดทีหลัง (ทับสีเหลือง)
            },

            // ⚫ Layer 3 (บนสุด): เส้นขอบและจุด (คะแนนของคุณ - เฉพาะเส้น)
            {
              label: "คะแนนของคุณ",
              data: answers,
              backgroundColor: "transparent", // ไม่เอาสีพื้น (เดี๋ยวไปบัง Layer อื่น)
              borderColor: "black", // เส้นสีดำเข้ม
              borderWidth: 3,
              pointBackgroundColor: "black",
              pointBorderColor: "black",
              pointHoverBackgroundColor: "white",
              pointHoverBorderColor: "black",
              pointRadius: 6, // จุดใหญ่ชัดเจน
              fill: false, // ไม่ต้อง Fill แล้ว
              order: 1, // วาดหลังสุด (อยู่บนสุดเสมอ)
            },
          ],
        },
        options: {
          font: {
            family: "'Anuphan Variable'", // ต้องตรงกับชื่อใน Fontsource
            size: 14,
          },
          scales: {
            r: {
              min: 0,
              max: 3,
              ticks: {
                stepSize: 1,
                display: false, // ซ่อนตัวเลขบนแกน (เพื่อให้ดูสะอาดเหมือนรูป)
              },
              grid: {
                color: "rgba(0,0,0,0.1)",
                circular: false, // เปลี่ยนเส้น Grid เป็นเหลี่ยมๆ ตามรูป
              },
              angleLines: { color: "rgba(0,0,0,0.1)" },
              pointLabels: {
                font: { size: 14, weight: "bold" }, // ปรับตัวเลขหัวข้อให้ใหญ่ขึ้น
                color: "#666",
              },
            },
          },
          plugins: {
            legend: { display: false }, // ซ่อน Legend ด้านบน
          },
        },
      });
    }

    // (ส่วน Feedback คงเดิม...)
    const feedbackBox = document.getElementById("feedback-box");
    let feedback = "";
    if (total <= 9)
      feedback = `<span class="text-orange-600 font-bold text-xl">กลุ่มเริ่มเรียนรู้ (${total} คะแนน)</span><br>เราน่าจะพูดคุยทบทวนกำหนดทิศทางกันใหม่`;
    else if (total <= 18)
      feedback = `<span class="text-yellow-600 font-bold text-xl">กลุ่มกำลังพัฒนา (${total} คะแนน)</span><br>พยายามอีกหน่อยนะ เรากำลังจะได้เป็นช่างเชื่อมที่เจ๋งแล้ว`;
    else if (total <= 23)
      feedback = `<span class="text-blue-600 font-bold text-xl">กลุ่มเชี่ยวชาญ (${total} คะแนน)</span><br>ฉันเป็นช่างเชื่อมแล้ว อัพเลเวลต่อไม่รอละนะ`;
    else
      feedback = `<span class="text-purple-600 font-bold text-xl">กลุ่มยอดเยี่ยม (${total} คะแนน)</span><br>ฉันเป็นช่างเชื่อมที่เจ๋งสุดๆ น่าจะแบ่งปันบทเรียนนี้แก่ช่างเชื่อมคนอื่นๆ ได้`;

    feedbackBox.innerHTML = feedback;
  }

  // 🔥 เริ่มต้นการทำงาน (Main Logic)
  loadProgress(); // 1. โหลดข้อมูลก่อน

  // 2. เช็คว่าทำเสร็จไปแล้วหรือยัง?
  // ถ้าตอบครบทุกข้อแล้ว ให้เด้งไปหน้าผลลัพธ์เลย (ไม่ต้องทำใหม่)
  if (answers.every((a) => a !== null) && answers.length === questions.length) {
    calculateResult();
  } else {
    renderUI(); // ถ้ายังไม่เสร็จ ให้ render หน้าคำถามที่ทำค้างไว้
  }
</script>
