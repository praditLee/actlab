---
// ส่วนนี้คือ Server Script (จะไม่ทำงานตอนเปลี่ยนหน้าใน Client)
import "../styles/global.css";
---

<div id="assessment-widget" class="w-full mx-auto font-sans">
  <div
    id="quiz-view"
    class="bg-[#B4E489] -mx-10 md:mx-auto rounded-none md:rounded-3xl overflow-hidden shadow-xl px-6 md:px-8"
  >
    <div class="relative pb-0 flex flex-col items-center text-center">
      <div class="w-full mb-[-200px] overflow-hidden">
        <img
          id="q-image"
          src=""
          alt="Question Image"
          class="w-full h-full object-contain crop-image-top"
        />
      </div>
    </div>

    <div class="bg-[#B4E489] p-2 md:p-6 mt-16 md:-mt-[100px] pb-8">
      <div id="options-container" class="flex flex-col gap-3"></div>

      <div class="flex justify-between items-center mt-8 px-2">
        <button
          id="btn-prev"
          class="text-sm px-6 py-2 rounded-full bg-white/40 hover:bg-white/60 text-black font-bold disabled:opacity-0 transition-all"
        >
          ← ย้อนกลับ
        </button>

        <span id="step-indicator" class="font-bold text-black/60">1 / 9</span>

        <button
          id="btn-next"
          class="text-sm px-6 py-2 rounded-full bg-black text-white hover:bg-gray-800 font-bold shadow-lg transition-all"
        >
          ถัดไป →
        </button>
      </div>
    </div>
  </div>

  <div
    id="result-view"
    class="hidden bg-[#B4E489] -mx-10 md:mx-auto rounded-none md:rounded-3xl overflow-hidden shadow-xl p-6 md:p-8 text-center"
  >
    <h2 class="text-3xl font-bold text-[#A3D983] mb-6">สรุปผลการประเมิน</h2>
    <div class="w-full max-w-md mx-auto mb-8">
      <canvas id="radarChart" class="w-full max-w-md mx-auto"></canvas>
    </div>
    <div id="feedback-box" class="p-6 rounded-xl bg-gray-50 text-left"></div>
    <button
      onclick="window.restartQuiz()"
      class="mt-8 px-8 py-3 bg-white text-black font-bold rounded-full hover:brightness-110 transition"
    >
      ทำแบบประเมินอีกครั้ง
    </button>
  </div>
</div>

<style>
  .crop-image-top {
    /*
     * clip-path: inset(Top Right Bottom Left);
     * ค่า Bottom 50% คือการตัดส่วนล่างออกไป 50% ของความสูงภาพ
     */
    clip-path: inset(0 0 45% 0);
  }
</style>

<script>
